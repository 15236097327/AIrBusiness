<Window x:Class="FlightDispatchClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        Title="航空大亨：极限调度 (Aviation Tycoon) - MMO Edition" Height="850" Width="1440" 
        Icon="pack://application:,,,/im1001.ico"
        Background="#0F0F15" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#181824" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="✈️ AOC 调度中心" Foreground="#00E5FF" FontSize="26" FontWeight="Black" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                    <Button x:Name="LoadDataBtn" Content="🌐 载入航空大亨世界 (Top 60)" Click="LoadDataBtn_Click" Height="45" Margin="0,0,0,12" Background="#007ACC" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="PauseGameBtn" Content="⏸️ 战术暂停 (Bullet Time)" Click="PauseGameBtn_Click" Height="45" Margin="0,0,0,15" Background="#FF8C00" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="BtnPersonalRecord" Content="📊 我的专属服役档案" Click="BtnPersonalRecord_Click" Height="45" Margin="0,0,0,15" Background="#8A2BE2" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="BtnGlobalLeaderboard" Content="🏆 全球联网名人堂" Click="BtnGlobalLeaderboard_Click" Height="45" Margin="0,0,0,15" Background="DarkGoldenrod" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand"/>

                    <Separator Margin="0,15,0,20" Background="#3F3F4E" Height="2"/>

                    <TextBlock Text="🚨 全网枢纽压力实时监控" Foreground="#8A8A9D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="UrgentAirportsList" Background="Transparent" BorderThickness="0" 
                         SelectionChanged="UrgentAirportsList_SelectionChanged" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252536" CornerRadius="6" Margin="0,0,0,10" Padding="12" Width="240" Cursor="Hand">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding CurrentPassengers, StringFormat='滞留: {0:N0}'}" Foreground="#FF4D4D" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding CurrentPassengers}" Maximum="{Binding MaxCapacity}" 
                                                 Height="6" Margin="0,8,0,0" Foreground="Crimson" Background="#111111" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#0A0A0F" Margin="10" CornerRadius="10" ClipToBounds="True">
            <Grid>
                <gmap:GMapControl x:Name="MainMap" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25" 
                        Background="#CC111118" BorderBrush="Gold" BorderThickness="2" CornerRadius="8" Padding="20,12">
                    <TextBlock x:Name="TxtFunds" Text="💰 资金: 1,000,000,000" 
                               Foreground="Gold" FontSize="24" FontWeight="Black" FontFamily="Consolas"/>
                </Border>

                <Border x:Name="AirportInfoPanel" Visibility="Collapsed" 
                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="25" Width="320" Background="#E615151A" 
                        BorderBrush="#FF4B4B" BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock x:Name="TxtAirportName" FontSize="20" FontWeight="Black" Foreground="White" Text="📍 机场名称" HorizontalAlignment="Left"/>
                            <Button Content="✕" Click="ClosePanel_Click" Foreground="Gray" Background="Transparent" BorderThickness="0" FontSize="16" HorizontalAlignment="Right" Cursor="Hand"/>
                        </Grid>

                        <TextBlock x:Name="TxtAirportLevel" FontSize="14" Foreground="#DDDDDD" Margin="0,0,0,5" Text="⭐ 等级: Lv.1"/>
                        <TextBlock x:Name="TxtAirportPax" FontSize="16" Foreground="#FF4D4D" FontWeight="Bold" Margin="0,0,0,15" Text="👥 当前滞留: 0 人"/>

                        <Border Background="#1A1A24" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                            <TextBlock x:Name="TxtDestinations" Foreground="#00E5FF" FontSize="13" TextWrapping="Wrap" Text="📡 雷达侦听: 等待信号..."/>
                        </Border>

                        <TextBlock Text="✈ 驻扎机队管理 (点击卡片升级):" Foreground="#AAAAAA" Margin="0,0,0,8" FontWeight="Bold" FontSize="13"/>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                            <StackPanel x:Name="FleetContainer"/>
                        </ScrollViewer>

                        <Button x:Name="UpgradeAirportBtn" Content="⬆️ 扩建机场容量 (¥ 1.5 亿)" Background="DarkGoldenrod" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Height="36" Click="UpgradeAirportBtn_Click" Cursor="Hand"/>
                        <Button x:Name="BuyLocalPlaneBtn" Content="✈ 购入全新客机 (¥ 1.5 亿)" Background="#2E8B57" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Height="36" Click="BuyLocalPlaneBtn_Click" Cursor="Hand"/>
                        <Button x:Name="DrawRouteBtn" Content="🔗 开通跨区航线 (鼠标连线)" Background="#007ACC" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,0" Height="36" Click="DrawRouteBtn_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="GameOverOverlay" Visibility="Collapsed" Background="#F205050A" Grid.ColumnSpan="2" Panel.ZIndex="9999">
            <Border Background="#1E1E28" BorderBrush="Crimson" BorderThickness="2" CornerRadius="12" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" Width="550">
                <StackPanel>
                    <TextBlock Text="🚨 航 空 帝 国 已 破 产" FontSize="32" FontWeight="Black" Foreground="Crimson" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="TxtFailReason" Text="💥 爆仓节点: 某某机场" FontSize="15" Foreground="Orange" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>

                    <Border Background="#252536" CornerRadius="8" Padding="25" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock x:Name="TxtFinalDays" Text="🏆 存活时间: 0 天" FontSize="20" FontWeight="Bold" Foreground="Gold" Margin="0,5"/>
                            <TextBlock x:Name="TxtFinalPax" Text="👥 累计运送: 0 人" FontSize="18" Foreground="White" Margin="0,5"/>
                            <TextBlock x:Name="TxtFinalFunds" Text="💰 最终结余: ¥ 0" FontSize="18" Foreground="LimeGreen" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <TextBlock Text="🧑‍✈️ 指挥官代号:" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox x:Name="TxtPlayerName" Width="180" Text="AOC-001" FontSize="16" FontWeight="Bold" Padding="6" VerticalAlignment="Center" Background="#111" Foreground="#00E5FF" BorderBrush="Gray"/>
                    </StackPanel>

                    <Grid Width="450" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🏆 仅提交基础战绩" Background="#007ACC" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Margin="0,0,5,0" Cursor="Hand" Click="SubmitScoreBtn_Click"/>
                        <Button x:Name="BtnUploadReport" Grid.Column="1" Content="📤 授权并上传详细数据" Background="#DAA520" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Margin="5,0,0,0" Cursor="Hand" Click="UploadReportBtn_Click"/>
                    </Grid>

                    <Button Content="📥 从云端拉取并下载我的战报 (CSV)" Background="#2E8B57" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Margin="0,0,0,12" Cursor="Hand" Click="DownloadReportBtn_Click"/>
                    <Button Content="🔄 抹除记录，直接重新开局" Background="#8B0000" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Cursor="Hand" Click="RestartGameBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="LeaderboardOverlay" Visibility="Collapsed" Background="#F205050A" Grid.ColumnSpan="2" Panel.ZIndex="10000">
            <Border Background="#1E1E28" BorderBrush="Gold" BorderThickness="2" CornerRadius="12" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="35" Width="650">
                <StackPanel>
                    <TextBlock Text="🏆 全 球 联 网 名 人 堂" FontSize="28" FontWeight="Black" Foreground="Gold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Button Content="🛡️ 生存专家榜" Background="#007ACC" Foreground="White" Width="160" Height="40" FontSize="15" FontWeight="Bold" Margin="0,0,15,0" Cursor="Hand" Click="LoadSurvivalBoard_Click"/>
                        <Button Content="💰 财富大亨榜" Background="DarkGoldenrod" Foreground="White" Width="160" Height="40" FontSize="15" FontWeight="Bold" Cursor="Hand" Click="LoadWealthBoard_Click"/>
                    </StackPanel>

                    <Grid Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="指挥官代号" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="0"/>
                        <TextBlock Text="存活天数" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="1"/>
                        <TextBlock Text="累计运送" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="2"/>
                        <TextBlock Text="最终资产" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="3"/>
                    </Grid>
                    <Separator Background="#3F3F4E" Margin="0,0,0,10" Height="2"/>

                    <ListBox x:Name="LeaderboardList" Background="Transparent" BorderThickness="0" MaxHeight="350" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="560" Margin="5,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding PlayerName}" Foreground="White" FontWeight="Bold" FontSize="17" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SurvivedDays, StringFormat={}{0} 天}" Foreground="Gold" FontSize="17" FontWeight="Black" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TransportedPax, StringFormat={}{0:N0} 人}" Foreground="#00E5FF" FontSize="15" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinalFunds, StringFormat=¥ {0:N0}}" Foreground="LimeGreen" FontSize="15" FontWeight="Bold" Grid.Column="3" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="🔙 关闭排行榜" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Margin="0,30,0,0" Cursor="Hand" Click="CloseLeaderboardBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="PersonalHistoryOverlay" Visibility="Collapsed" Background="#F205050A" Grid.ColumnSpan="2" Panel.ZIndex="15000">
            <Border Background="#1E1E28" BorderBrush="#8A2BE2" BorderThickness="2" CornerRadius="12" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="35" Width="700">
                <StackPanel>
                    <TextBlock x:Name="TxtHistoryTitle" Text="🧑‍✈️ 指挥官 [未登录] 的服役档案" FontSize="26" FontWeight="Black" Foreground="#8A2BE2" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <Border Background="#252536" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="总服役局数" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtTotalGames" Text="0" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="累计存活天数" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtTotalDays" Text="0" Foreground="Gold" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="历史总运送量" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtTotalPax" Text="0" Foreground="#00E5FF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="创造总财富" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtTotalWealth" Text="¥ 0" Foreground="LimeGreen" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="退役时间 (服务器)" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="0"/>
                        <TextBlock Text="存活天数" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="1"/>
                        <TextBlock Text="本局运送量" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="2"/>
                        <TextBlock Text="本局最终资产" Foreground="#AAAAAA" FontSize="15" FontWeight="Bold" Grid.Column="3"/>
                    </Grid>
                    <Separator Background="#3F3F4E" Margin="0,0,0,10" Height="2"/>

                    <ListBox x:Name="PersonalHistoryList" Background="Transparent" BorderThickness="0" MaxHeight="250" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="600" Margin="5,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FormattedDate}" Foreground="White" FontSize="14" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SurvivedDays, StringFormat={}{0} 天}" Foreground="Gold" FontSize="16" FontWeight="Black" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TransportedPax, StringFormat={}{0:N0} 人}" Foreground="#00E5FF" FontSize="15" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinalFunds, StringFormat=¥ {0:N0}}" Foreground="LimeGreen" FontSize="15" FontWeight="Bold" Grid.Column="3" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="🔙 关 闭 档 案 柜" Background="#8A2BE2" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Margin="0,20,0,0" Cursor="Hand" Click="ClosePersonalHistoryBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="LoginOverlay" Visibility="Visible" Background="#FA05050A" Grid.ColumnSpan="2" Panel.ZIndex="20000">
            <Border Background="#1E1E28" BorderBrush="#00E5FF" BorderThickness="2" CornerRadius="12" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" Width="450">
                <StackPanel>
                    <TextBlock Text="🌐 航 空 局 内 部 网 络" FontSize="24" FontWeight="Black" Foreground="#00E5FF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="AOC COMMAND CENTER" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30" FontFamily="Consolas"/>

                    <TextBlock Text="🧑‍✈️ 指挥官代号 (账号):" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtLoginUsername" FontSize="16" FontWeight="Bold" Padding="8" Background="#111" Foreground="White" BorderBrush="Gray" Margin="0,0,0,20"/>

                    <TextBlock Text="🔑 访问口令 (密码):" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="TxtLoginPassword" FontSize="16" FontWeight="Bold" Padding="8" Background="#111" Foreground="White" BorderBrush="Gray" Margin="0,0,0,30"/>

                    <Button x:Name="BtnLogin" Content="🔓 登 录 调 度 系 统" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Margin="0,0,0,15" Cursor="Hand" Click="BtnLogin_Click"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="📝 注册新指挥官" Background="#2E8B57" Foreground="White" FontSize="14" FontWeight="Bold" Height="35" Margin="0,0,5,0" Cursor="Hand" Click="BtnRegister_Click"/>
                        <Button Grid.Column="1" Content="❌ 退出系统" Background="#8B0000" Foreground="White" FontSize="14" FontWeight="Bold" Height="35" Margin="5,0,0,0" Cursor="Hand" Click="BtnExit_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>